  "keyFeatures": [
    "Workspace and project management with role-based access control",
    "Multi-source data connectivity (databases, warehouses, SaaS tools)",
    "Interactive dashboards with drag-and-drop layout",
    "Scheduled report delivery via email and Slack",
    "Pre-built connector catalog with OAuth 2.0, API key, and service account auth",
    "CRM sync for Salesforce, HubSpot, Pipedrive, Zoho CRM, and Dynamics 365",
    "Webhook event delivery with HMAC-SHA256 signature verification",
    "Custom roles with granular permissions (Business/Enterprise plans)",
    "Bulk CSV user import and team management",
    "SSO via SAML 2.0 and OIDC"
  ],
  "publicApiSurface": [
    "GET /workspaces",
    "POST /workspaces/{workspace}/projects",
    "GET /workspaces/{workspace}/members",
    "POST /workspaces/{workspace}/members/invite",
    "GET /analytics/data-sources",
